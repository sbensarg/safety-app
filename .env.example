# ── DATABASE ──
# Railway injects this automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── SERVER ──
PORT=3000
NODE_ENV=production

# ── SECURITY — CHANGE THESE IN PRODUCTION ──
JWT_SECRET=change-me-to-a-long-random-string-in-prod
ADMIN_SECRET=change-me-admin-secret-in-prod
ADMIN_USER=admin
ADMIN_PASS=safety2024

# ── EMAIL (SMTP) ──
# Use Gmail App Password, Resend, SendGrid, or Mailgun
# Gmail: go to Google Account > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── APP URL (used in verification email links) ──
# Set this to your Railway public URL after deploy
APP_URL=https://your-app.railway.app
